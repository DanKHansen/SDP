# ==========================================
# 1. OpenTofu / Terraform State (CRITICAL)
# ==========================================
*.tfstate
*.tfstate.*
*.tfstate.backup
.tofu/
.terraform/
.tfplan
.tfplan.*

# ==========================================
# 2. Secrets & Credentials (FIXED PATHS)
# ==========================================
# CRITICAL: Ignore specific OpenBao secrets directory (was missing!)
security/openbao-secrets/

# Generic secret patterns (safe defaults)
*.pem
*.key
*.p12
*.pfx
*.crt
env/.env
.env
.env.local
.env.production
credentials.json
secret.yaml

# ==========================================
# 3. Python, dbt & Data Tools (PATH ADJUSTED)
# ==========================================
# Python cache
__pycache__/
*.py[cod]
*$py.class
build/
dist/
*.egg-info/
.eggs/
venv/
env/
.venv/

# dbt - Updated to match your 'data-platform/transformation/dbt-projects' structure
data-platform/transformation/dbt-projects/logs/
data-platform/transformation/dbt-projects/target/
data-platform/transformation/dbt-projects/dbt_packages/

# Great Expectations - Updated to match 'data-platform/data-quality/great-expectations'
data-platform/data-quality/great-expectations/uncommitted/
data-platform/data-quality/great-expectations/plugins/

# NiFi Local State (Large files)
nifi/nifi-logs/
nifi/database_repository/
nifi/version_repository/
nifi/content_repository/
nifi/provenance_repository/
nifi/state/
data-platform/ingestion/nifi-flows/*.log # Optional: if logs end up in flow files

# ==========================================
# 4. Kubernetes & Helm
# ==========================================
.kube/
helm-debug/
Chart.lock
# Do not ignore Chart.yaml or values.yaml! Only generated artifacts.

# ==========================================
# 5. IDE & OS
# ==========================================
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
*.sublime-*

# ==========================================
# 6. Logs & Temp
# ==========================================
*.log
logs/
tmp/
*.tmp
*.bak

# ==========================================
# 7. Build & CI
# ==========================================
node_modules/
coverage/
.nyc_output/
.jest/

# ==========================================
# 8. Local Dev Overrides
# ==========================================
docker-compose.override.yml
docker-compose.local.yml
local-dev/.env
local-dev/kind-cluster/.kubeconfig

# ==========================================
# 9. Local Infrastructure Config (CRITICAL)
# ==========================================
# Ignore all .tfvars files (contains tokens, IPs, SSH IDs)
# You MUST manually un-ignore template files if you have them (e.g., *.tfvars.tmpl)
*.tfvars
!*.tfvars.example
!*.tfvars.template

# Ignore generated plan files (already covered by .tfplan but explicit is better)
*.tfplan
