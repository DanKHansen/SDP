# ---------------------------------------------------------
# SDP Infrastructure Configuration Template
# ---------------------------------------------------------
# IMPORTANT: 
# 1. Copy this file to 'dev.tfvars' before running 'tofu plan'.
# 2. NEVER commit 'dev.tfvars' to git (it is in .gitignore).
# 3. Replace all values below with your actual credentials.
# ---------------------------------------------------------

# Hetzner Cloud Provider
# Set HCLOUD_TOKEN environment variable instead of uncommenting this line
# hcloud_token = "YOUR_HETZNER_API_TOKEN" 

location      = "hel1"           # e.g., hel1, fsn1, nbg1
network_cidr  = "10.0.0.0/16"    # Private network CIDR range
ssh_key_id    = "YOUR_SSH_KEY_ID" # Hetzner SSH Key ID (found in HC Console)
admin_ip      = "YOUR_PUBLIC_IP/32" # Your home/office IP for SSH access

# Server Specs
server_type   = "cx53"           # e.g., cax11, cx22, cx53
image         = "ubuntu-24.04"   # OS image name

# Cluster Configuration
node_count    = 3                # Number of K3s nodes

# K3s Configuration
k3s_version   = "v1.30.2+k3s1"   # Pin to a specific stable version
# Generate a secure token: openssl rand -hex 16
k3s_token     = "GENERATE_SECURE_TOKEN_HERE" 